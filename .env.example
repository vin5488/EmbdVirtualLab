# VirtualLab Platform — Environment Variables
# Copy this file to .env and fill in your values.
# Lines starting with # are comments.

# ─────────────────────────────────────────────────────────
# SERVER
# ─────────────────────────────────────────────────────────
PORT=8080
WORKERS=4
MAX_COMPILES=12
NODE_ENV=production

# ─────────────────────────────────────────────────────────
# SECURITY  ← All fields below MUST be changed in production
# ─────────────────────────────────────────────────────────

# JWT Secret — must be a long, random, unique string.
# Generate one:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# The server will REFUSE TO START in production if this is empty or the default.
JWT_SECRET=CHANGE_ME_generate_a_random_secret_at_least_64_chars

# Admin credentials
ADMIN_EMAILS=admin@yourdomain.com          # Comma-separated if multiple
ADMIN_PASS=CHANGE_ME_strong_password       # Server refuses to start if still 'admin123'

# Debug mode — NEVER set to true in production (exposes OTP codes in API responses)
DEBUG_AUTH=false

# ─────────────────────────────────────────────────────────
# CORS  ← Lock to your deployed domain in production
# Leave blank to allow all origins (fine for local dev, NOT for prod)
# Multiple domains: CORS_ORIGIN=https://a.com,https://b.com
# ─────────────────────────────────────────────────────────
CORS_ORIGIN=

# ─────────────────────────────────────────────────────────
# DATABASE
# ─────────────────────────────────────────────────────────
DB_PATH=./data/virtuallab.db

# ─────────────────────────────────────────────────────────
# WHITELIST
# When true, only emails in the whitelist table can register.
# ─────────────────────────────────────────────────────────
ENABLE_WHITELIST=true

# ─────────────────────────────────────────────────────────
# SMTP — for OTP email delivery
# ─────────────────────────────────────────────────────────
SMTP_HOST=smtp.yourmailprovider.com
SMTP_PORT=587
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password
SMTP_FROM="VirtualLab <noreply@yourdomain.com>"

# ─────────────────────────────────────────────────────────
# TOPIC FILTER  (leave blank to show ALL topics)
# Comma-separated topic IDs to restrict which topics are visible.
# Available: C_INT, C_ADV, CPP_INT, CPP_ADV,
#            MCU_SIM, MCU_SIM_RP2040, MBD_FUND, MBD_ADV
# Example (C & C++ only): TOPIC_FILTER=C_INT,C_ADV,CPP_INT,CPP_ADV
# ─────────────────────────────────────────────────────────
TOPIC_FILTER=

# ─────────────────────────────────────────────────────────
# BRANDING  (optional, for white-label instances)
# ─────────────────────────────────────────────────────────
PLATFORM_TITLE=SkillLyncVirtualLab
PLATFORM_SUBTITLE=Industrial Grade Embedded & ECU Project Platform
