        "name": "main.c",
        "content": "#include <stdio.h>\n\nint countSetBits(unsigned int num)\n{\n    int count = 0;\n\n    while (num)\n    {\n        count += (num & 1);\n        num >>= 1;\n    }\n\n    return count;\n}\n\nint main()\n{\n    int n;\n    scanf(\"%d\", &n);\n\n    printf(\"%d\", countSetBits((unsigned int)n));\n\n    return 0;\n}"
